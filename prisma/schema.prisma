generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  credits      Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  campaigns    Campaign[]
  payments     Payment[]
}

model Campaign {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  scravioCampaignId    String?
  spherescoutSearchId  String?
  searchleadsData      String?
  source               String   @default("scravio")
  name                 String
  platform             String
  extractionType       String
  status               String   @default("PENDING")
  targetCount          Int
  creditsUsed          Int      @default(0)
  creditsRefunded      Int      @default(0)
  config               String
  leadsFound           Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  stripeSessionId   String   @unique
  amount            Int
  credits           Int
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
}
